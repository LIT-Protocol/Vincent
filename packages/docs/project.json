{
  "name": "vincent-docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/docs/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/docs/jest.config.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docusaurus build",
        "cwd": "packages/docs"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docusaurus start",
        "cwd": "packages/docs"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docusaurus start",
        "cwd": "packages/docs"
      }
    },
    "clear": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docusaurus clear",
        "cwd": "packages/docs"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docusaurus serve",
        "cwd": "packages/docs"
      }
    },
    "update-api-docs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docusaurus clear && docusaurus build",
        "cwd": "packages/docs"
      }
    }
  }
}
